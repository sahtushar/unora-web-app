# Production environment template (Unora API)
#
# Copy to a local file (gitignored):  cp env.prod.example env.prod
# Then paste values into Render / Vercel dashboards, or load env.prod only on a trusted machine.
# Never commit env.prod with real secrets.
#
# =============================================================================
# RENDER — Web Service + Postgres + Key Value in the SAME region (recommended)
# =============================================================================
# Use INTERNAL URLs so traffic stays on Render’s private network (no public DB port).
#
# DATABASE_URL — Dashboard → your Postgres instance → Connect → Internal Database URL
#   Example shape: postgresql://USER:PASSWORD@HOST.internal/DBNAME
# DATABASE_URL=
#
# REDIS_URL — Upstash: Connect → TCP tab (not REST). Use TLS: rediss://default:TOKEN@....upstash.io:6379
#   If you only have redis:// from redis-cli, hosts *.upstash.io are auto-upgraded to rediss:// in code.
#   Local Docker Redis: redis://127.0.0.1:6379
# REDIS_URL=
#
# =============================================================================
# VERCEL (serverless API on Vercel)
# =============================================================================
# Step-by-step: README → “Deploy on Vercel” → “Postgres and Redis on Vercel”.
#
# Vercel does NOT run inside Render’s private network. Render “Internal” Postgres/Redis
# URLs are NOT reachable from Vercel functions.
#
# Typical stack: Neon (DATABASE_URL) + Upstash TCP rediss:// (REDIS_URL) pasted in
# Vercel → Project → Settings → Environment Variables.
#
# Profile photos: USER_PHOTOS_STORAGE=local is rejected when VERCEL is set. Use
# USER_PHOTOS_STORAGE=postgres (BLOBs in DB; set PUBLIC_MEDIA_BASE_URL to this API’s /v1/media) or
# s3 + S3_* and a CDN/ bucket URL in PUBLIC_MEDIA_BASE_URL (see README “Deploy on Vercel” step 6).
#
# DATABASE_URL=
# REDIS_URL=
#
# =============================================================================
# SHARED — required for all hosts (generate strong random values)
# =============================================================================
NODE_ENV=production
HOST=0.0.0.0
# Render sets PORT automatically; optional locally:
# PORT=8000

JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_AT_LEAST_32_CHARS
OTP_PEPPER=REPLACE_WITH_RANDOM_AT_LEAST_16_CHARS

GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com,your-ios-client-id.apps.googleusercontent.com

# Comma-separated browser origins (your deployed frontend(s), no trailing slashes on entries)
CORS_ORIGINS=https://your-frontend.example.com,https://www.your-frontend.example.com

# Behind TLS-terminating proxy (Render, Vercel): set TRUST_PROXY=true
# Use TRUST_PROXY_HOPS=1 for a single edge (default). Increase only if you have extra reverse proxies.
TRUST_PROXY=true
TRUST_PROXY_HOPS=1
REQUIRE_HTTPS=true

# Public base for profile image URLs (no trailing slash). On Render + local media storage:
#   https://YOUR-SERVICE.onrender.com/v1/media
PUBLIC_MEDIA_BASE_URL=https://YOUR-SERVICE.onrender.com/v1/media

ENABLE_OPENAPI_UI=false

USER_PHOTOS_STORAGE=local
USER_PHOTOS_LOCAL_DIR=data/user-photos

# Serverless (no disk): keep images in Postgres
# USER_PHOTOS_STORAGE=postgres
# PUBLIC_MEDIA_BASE_URL=https://YOUR-SERVICE.onrender.com/v1/media

# For real uploads to object storage, set S3_* in the dashboard:
# USER_PHOTOS_STORAGE=s3
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# PUBLIC_MEDIA_BASE_URL=https://your-cdn-or-bucket-base.example.com
